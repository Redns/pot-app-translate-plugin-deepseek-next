{
  "id": "plugin.com.krins.deepseek.next",
  "plugin_type": "translate",
  "icon": "deepseek.svg",
  "display": "deepseek-next",
  "homepage": "https://github.com/Redns/pot-app-translate-plugin-deepseek-next",
  "needs": [
    {
      "key": "model",
      "display": "模型选择",
      "type": "select",
      "options": {
        "deepseek-v4-flash": "deepseek-v4-flash",
        "deepseek-v4-pro": "deepseek-v4-pro"
      },
      "default": "deepseek-v4-flash"
    },
    {
      "key": "thinking",
      "display": "思考模式",
      "type": "select",
      "options": {
        "disabled": "关闭",
        "enabled": "开启"
      },
      "default": "disabled"
    },
    {
      "key": "apiKey",
      "display": "API 密钥",
      "type": "input"
    }
  ],
  "language": {
    "auto": "auto",
    "zh_cn": "zh",
    "zh_tw": "zh_HANT",
    "en": "en",
    "ja": "ja",
    "ko": "ko",
    "fr": "fr",
    "es": "es",
    "ru": "ru",
    "de": "de",
    "it": "it",
    "tr": "tr",
    "pt_pt": "pt",
    "pt_br": "pt",
    "vi": "vi",
    "id": "id",
    "th": "th",
    "ms": "ms",
    "ar": "ar",
    "hi": "hi",
    "mn_cy": "mn",
    "mn_mo": "mn",
    "km": "km",
    "nb_no": "no",
    "nn_no": "no",
    "fa": "fa"
  }
}
